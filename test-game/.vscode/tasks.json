{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "make",
      "args": ["BUILD=Debug", "-j8"],
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Build Release",
      "type": "shell",
      "command": "make",
      "args": ["BUILD=Release", "-j8"],
      "problemMatcher": ["$gcc"],
      "group": "build"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "make",
      "args": ["clean"],
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
